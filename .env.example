# BoondManager MCP Server — Configuration
#
# Copier ce fichier en .env et remplir les valeurs :
#   cp .env.example .env

# ─── API ────────────────────────────────────────────
# URL de base de l'API Boond (sans slash final)
BOOND_API_URL=https://ui.boondmanager.com/api

# ─── Authentification ───────────────────────────────
# Mode : "basic" ou "jwt"
BOOND_AUTH_MODE=basic

# === Basic Auth ===
# Activer dans Boond : Avatar > Configuration > "Allow API Rest calls using BasicAuth authentication"
BOOND_USERNAME=prenom.nom@entreprise.fr
BOOND_PASSWORD=

# === JWT Auth (alternative, recommandé en prod) ===
# User Token  : Mon compte > Configuration > Sécurité
# Client Token : Admin > Espace développeur > API / Sandbox
# Client Key   : Admin > Espace développeur > API / Sandbox
# BOOND_USER_TOKEN=
# BOOND_CLIENT_TOKEN=
# BOOND_CLIENT_KEY=

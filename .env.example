# BoondManager MCP Server — Configuration
#
# Copier ce fichier en .env et remplir les valeurs :
#   cp .env.example .env

# ─── Transport MCP ──────────────────────────────────
# "stdio" (défaut) : Claude Desktop, Claude Code, Cursor (subprocess local)
# "http"           : Streamable HTTP pour n8n, clients remote, multi-user
MCP_TRANSPORT=stdio

# Port HTTP (mode http uniquement, défaut: 3001)
# MCP_HTTP_PORT=3001

# ─── Pagination ─────────────────────────────────────
# Cap sur fetchAll:true (défaut: 500)
# BOOND_MAX_RESULTS=500

# ─── API ────────────────────────────────────────────
# URL de base de l'API Boond (sans slash final)
BOOND_API_URL=https://ui.boondmanager.com/api

# ─── Authentification ───────────────────────────────
# Mode : "basic" ou "jwt"
BOOND_AUTH_MODE=jwt

# === Basic Auth ===
# Activer dans Boond : Avatar > Configuration > "Allow API Rest calls using BasicAuth authentication"
# BOOND_USERNAME=prenom.nom@entreprise.fr
# BOOND_PASSWORD=

# === JWT Auth (recommandé) ===
# Mode JWT : "normal" (user-scoped) ou "god" (admin/elevated)
BOOND_JWT_MODE=normal

# User Token : Mon compte > Configuration > Sécurité
BOOND_USER_TOKEN=

# App Token : reçu via le signed request lors de l'installation OAuth
BOOND_APP_TOKEN=

# App Key : Admin > Espace développeur > API / Sandbox
# Utilisée pour signer les JWT en mode normal
BOOND_APP_KEY=

# === God mode (optionnel, pour opérations admin) ===
# Client Token : reçu via le signed request lors de l'installation OAuth
# BOOND_CLIENT_TOKEN=

# God Client Token : clé de signature pour les JWT en mode god
# BOOND_GOD_CLIENT_TOKEN=
